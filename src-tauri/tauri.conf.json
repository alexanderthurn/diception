{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DICEPTION",
  "version": "../package.json",
  "identifier": "com.feuerware.diception",
  "build": {
    "frontendDist": "../dist/",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DICEPTION",
        "additionalBrowserArgs": "",
        "width": 800,
        "height": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}